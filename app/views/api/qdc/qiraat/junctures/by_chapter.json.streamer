json.object! do
  json.chapter do
    json.object! do
      json.id @chapter.id
      json.chapter_number @chapter.chapter_number
      json.name_simple @chapter.name_simple
    end
  end

  json.junctures do
    json.array! @junctures do |juncture|
      json.partial! 'juncture', juncture: juncture
    end
  end

  json.pagination do
    json.object! do
      json.merge! @pagination
    end
  end
end
